# Example environment configuration for production
VITE_LOYTEC_BASE_URL=http://your-loytec-server.com
VITE_API_TIMEOUT=10000
VITE_DEV_MODE=false

# Hub URL for cross-origin SSO in development mode
# Only needed when running separate dev servers (not in production)
VITE_HUB_URL=http://localhost:8001

# Development authentication bypass (do NOT enable in production)
VITE_DEV_SKIP_AUTH=false