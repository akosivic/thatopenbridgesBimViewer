# Loytec Authentication Configuration
VITE_LOYTEC_BASE_URL=https://192.168.50.56

# Optional: API timeout in milliseconds (default: 10000)
VITE_API_TIMEOUT=10000

# Development settings
VITE_DEV_MODE=true

# Development-only authentication bypass (ONLY works in development mode)
# This will be automatically disabled in production builds
VITE_DEV_SKIP_AUTH=false