{
  "navigationFallback": {
    "rewrite": "/index.html"
  },
  "routes": [
    {
      "route": "/worldviewer/*",
      "allowedRoles": [
        "contributor",
        "owner",
        "reader"
      ]
    },
    {
      "route": "/error",
      "allowedRoles": [
        "anonymous",
        "authenticated",
        "contributor",
        "owner",
        "reader"
      ]
    },
    {
      "route": "/worldviewer",
      "allowedRoles": [
        "contributor",
        "owner",
        "reader"
      ]
    },
    {
      "route": "/api/streamifc",
      "methods": [
        "GET"
      ],
      "allowedRoles": [
        "contributor",
        "owner",
        "reader"
      ]
    }
  ],
  "platform": {
    "apiRuntime": "node:20"
  }
}