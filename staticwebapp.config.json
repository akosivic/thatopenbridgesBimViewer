{
  "navigationFallback": {
    "rewrite": "/ws/node/bimviewer/index.html"
  },
  "routes": [
    {
      "route": "/ws/node/bimviewer/worldviewer/*",
      "allowedRoles": [
        "contributor",
        "owner",
        "reader"
      ]
    },
    {
      "route": "/ws/node/bimviewer/error",
      "allowedRoles": [
        "anonymous",
        "authenticated",
        "contributor",
        "owner",
        "reader"
      ]
    },
    {
      "route": "/ws/node/bimviewer/worldviewer",
      "allowedRoles": [
        "contributor",
        "owner",
        "reader"
      ]
    },
    {
      "route": "/ws/node/api/streamIfc",
      "methods": [
        "GET"
      ],
      "allowedRoles": [
        "contributor",
        "owner",
        "reader"
      ]
    },
    {
      "route": "/ws/node/api/getDpsValues",
      "methods": [
        "GET"
      ],
      "allowedRoles": [
        "contributor",
        "owner",
        "reader"
      ]
    },
    {
      "route": "/ws/node/api/GetDpsMapValues",
      "methods": [
        "GET"
      ],
      "allowedRoles": [
        "contributor",
        "owner",
        "reader"
      ]
    }
  ],
  "platform": {
    "apiRuntime": "node:20"
  }
}