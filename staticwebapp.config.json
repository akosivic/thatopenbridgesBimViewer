{
  "navigationFallback": {
    "rewrite": "/index.html"
  },
  "routes": [
    {
      "route": "/worldviewer/*",
      "allowedRoles": [
        "contributor",
        "owner",
        "reader"
      ]
    },
    {
      "route": "/error",
      "allowedRoles": [
        "anonymous",
        "authenticated",
        "contributor",
        "owner",
        "reader"
      ]
    },
    {
      "route": "/worldviewer",
      "allowedRoles": [
        "contributor",
        "owner",
        "reader"
      ]
    },
    {
      "route": "/api/*",
      "allowedRoles": [
        "contributor",
        "owner",
        "reader"
      ]
    },
    {
      "route": "/.auth/login/aad",
      "allowedRoles": [
        "anonymous",
        "authenticated"
      ]
    }
  ],
  "platform": {
    "apiRuntime": "node:20"
  }
}